# Database Configuration
DB_PASSWORD=SecureP@ssw0rd123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bankingdb
DB_USER=bankinguser



# JWT Authentication (generate a secure random key for production)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# API Configuration
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# Expo/React Native
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# ==========================================
# AI ADVISOR (Amazon Bedrock)
# ==========================================
# Phase 1 — no AWS account needed:
#   Leave AWS vars blank and keep AI_MOCK_MODE=true
#   The app works end-to-end with a canned demo response (zero cost)
#
# Phase 2 — real AI responses:
#   1. Create a free AWS account at https://aws.amazon.com
#   2. Enable Amazon Bedrock access for Nova Lite in us-east-1
#   3. Create an IAM user with BedrockRuntime:InvokeModel permission
#   4. Fill in the three AWS vars below and set AI_MOCK_MODE=false

AI_MOCK_MODE=true                     # flip to false for real Bedrock calls
AI_MAX_TOKENS_PER_RESPONSE=512        # caps output tokens per request (cost control)

AWS_ACCESS_KEY_ID=                    # leave blank for Phase 1
AWS_SECRET_ACCESS_KEY=                # leave blank for Phase 1
AWS_REGION=us-east-1